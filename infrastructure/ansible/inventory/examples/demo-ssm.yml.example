# Mẫu tham khảo — file inventory thật: inventory/demo-ssm.yml (đuôi .yml, không dùng .yml.example làm -i).
#
# Ansible qua SSM — không cần SSH tới IP private.
#
# 1. Máy local: AWS CLI + Session Manager plugin
#    brew install --cask session-manager-plugin
# 2. IAM user/role của bạn cần quyền SSM (vd. AmazonSSMFullAccess hoặc StartSession tới instance).
# 3. Thay i-xxxxxxxx bằng Instance ID (EC2 console hoặc:
#    aws ec2 describe-instances --filters "Name=tag:Name,Values=crawler-demo-worker" ...
# 4. Cài collection: ansible-galaxy collection install amazon.aws
#
# Chạy:
#   ansible-playbook -i inventory/demo-ssm.yml playbooks/site.yml

all:
  vars:
    ansible_user: ec2-user
    ansible_connection: amazon.aws.aws_ssm
    ansible_aws_ssm_region: ap-southeast-1
    # Bắt buộc với một số phiên bản plugin (bucket tạm cho session):
    # ansible_aws_ssm_bucket_name: your-session-log-bucket
  children:
    crawler_demo:
      hosts:
        worker-1:
          ansible_host: i-REPLACE_WITH_INSTANCE_ID
