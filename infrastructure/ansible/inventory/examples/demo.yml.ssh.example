# Sao chép thành demo.yml và điền IP/DNS (ví dụ bastion + ProxyJump hoặc VPN tới subnet private).
# Worker EC2: Amazon Linux 2023, user mặc định ec2-user.

all:
  vars:
    ansible_user: ec2-user
    # ansible_ssh_private_key_file: ~/.ssh/your-key.pem
    # ansible_ssh_common_args: '-o ProxyJump=ec2-user@bastion-public-ip'
  children:
    crawler_demo:
      hosts:
        worker-1:
          # Private IP worker ASG (subnet private) — SSH qua bastion/VPN/SSM
          ansible_host: 10.0.12.92
