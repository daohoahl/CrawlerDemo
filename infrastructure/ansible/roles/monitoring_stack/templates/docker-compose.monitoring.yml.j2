version: "3.9"

services:
  prometheus:
    image: prom/prometheus:v2.55.1
    container_name: crawler-prometheus
    command:
      - --config.file=/etc/prometheus/prometheus.yml
      - --storage.tsdb.path=/prometheus
      - --storage.tsdb.retention.time=7d
    ports:
      - "{{ monitoring_prometheus_port }}:9090"
    volumes:
      - ./prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus-data:/prometheus
    extra_hosts:
      - "host.docker.internal:host-gateway"
    restart: unless-stopped

  loki:
    image: grafana/loki:3.1.1
    container_name: crawler-loki
    command: -config.file=/etc/loki/local-config.yml
    ports:
      - "{{ monitoring_loki_port }}:3100"
    volumes:
      - ./loki/loki-config.yml:/etc/loki/local-config.yml:ro
      - loki-data:/loki
    restart: unless-stopped

  promtail:
    image: grafana/promtail:3.1.1
    container_name: crawler-promtail
    command: -config.file=/etc/promtail/config.yml
    volumes:
      - ./promtail/promtail-config.yml:/etc/promtail/config.yml:ro
      - /var/log:/var/log:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
    restart: unless-stopped
    depends_on:
      - loki

  node-exporter:
    image: prom/node-exporter:v1.8.2
    container_name: crawler-node-exporter
    command:
      - --path.rootfs=/host
    ports:
      - "{{ monitoring_node_exporter_port }}:9100"
    volumes:
      - /:/host:ro,rslave
    restart: unless-stopped

  cadvisor:
    image: gcr.io/cadvisor/cadvisor:v0.49.1
    container_name: crawler-cadvisor
    ports:
      - "{{ monitoring_cadvisor_port }}:8080"
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro
    restart: unless-stopped

  grafana:
    image: grafana/grafana:11.2.2
    container_name: crawler-grafana
    ports:
      - "{{ monitoring_grafana_port }}:3000"
    environment:
      GF_SECURITY_ADMIN_USER: "{{ monitoring_grafana_admin_user }}"
      GF_SECURITY_ADMIN_PASSWORD: "{{ monitoring_grafana_admin_password }}"
      GF_DATE_FORMATS_DEFAULT_TIMEZONE: "{{ monitoring_grafana_default_timezone }}"
    volumes:
      - ./grafana/provisioning:/etc/grafana/provisioning:ro
      - ./grafana/dashboards:/var/lib/grafana/dashboards:ro
      - grafana-data:/var/lib/grafana
    restart: unless-stopped
    depends_on:
      - prometheus
      - loki

volumes:
  prometheus-data:
  loki-data:
  grafana-data:
